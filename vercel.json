{
  "version": 2,
  "builds": [
    { "src": "api/*.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/predict_game", "dest": "/api/predict_game.py" },
    { "src": "/api/predict_tournament", "dest": "/api/predict_tournament.py" },
    { "src": "/api/bracket", "dest": "/api/bracket.py" },
    { "src": "/api/chat", "dest": "/api/chat.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
